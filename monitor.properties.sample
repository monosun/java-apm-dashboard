# ============================================================
#  Java APM Dashboard v1.5.0 — 설정 샘플 파일
#  https://github.com/monosun/java-apm-dashboard
# ============================================================
#
#  [사용 방법]
#  이 파일을 복사하여 JAR 파일과 같은 디렉터리에
#  monitor.properties 로 저장하면 자동으로 적용됩니다.
#
#    java-monitor-1.5.0.jar
#    monitor.properties        ← 이 파일 (복사 후 이름 변경)
#
#  특정 경로를 직접 지정할 수도 있습니다:
#    java -jar java-monitor-1.5.0.jar /etc/monitor/prod.properties
#
#  [적용 우선순위]  낮음 ─────────────────────── 높음
#    JAR 내 기본값  →  이 파일(외부)  →  -D 시스템 속성
#
#  [시스템 속성 덮어쓰기 예시]
#    java -Dserver.http.port=8080 -Dremote.jmx.enabled=true \
#         -jar java-monitor-1.5.0.jar
# ============================================================


# ============================================================
#  [1] HTTP 서버 설정 (server.*)
# ============================================================

# 대시보드·API·Prometheus scrape 요청을 받는 HTTP 포트
# - 대시보드 URL: http://localhost:{port}/dashboard
# - 포트 충돌 시 18080, 9091 등 다른 값으로 변경하세요
# 기본값: 9090
server.http.port=9090

# JVM 스냅샷을 콘솔에 출력하는 주기 (초)
# - 0 으로 설정하면 콘솔 출력이 비활성화됩니다
# - 운영 환경에서는 0 또는 60 이상을 권장합니다
# 기본값: 15
server.print.interval.sec=15

# 트랜잭션 스팬을 보관하는 링 버퍼 크기 (최근 N건 보관)
# - 버퍼가 가득 차면 가장 오래된 스팬부터 제거됩니다
# - 스팬 1건 ≈ 1~2 KB (기본값 1000건 ≈ 1~2 MB)
# 기본값: 1000
server.span.buffer.size=1000


# ============================================================
#  [2] 원격 JVM 모니터링 — JMX (remote.*)
# ============================================================
#
#  대상 JVM 시작 시 아래 JVM 옵션을 추가해야 합니다:
#
#  ● 인증 없음 (개발/내부망)
#    java -Dcom.sun.management.jmxremote \
#         -Dcom.sun.management.jmxremote.port=9999 \
#         -Dcom.sun.management.jmxremote.rmi.port=9999 \
#         -Dcom.sun.management.jmxremote.authenticate=false \
#         -Dcom.sun.management.jmxremote.ssl=false \
#         -Djava.rmi.server.hostname=<서버_IP> \
#         -jar myapp.jar
#
#  ● 인증 있음 (운영 환경 권장)
#    -Dcom.sun.management.jmxremote.authenticate=true
#    -Dcom.sun.management.jmxremote.password.file=./jmxremote.password
#    -Dcom.sun.management.jmxremote.access.file=./jmxremote.access
#
#  ● Docker 환경 주의사항
#    -Djava.rmi.server.hostname 을 컨테이너 외부에서 접근 가능한 IP로 설정해야 합니다.
# ============================================================

# true 로 변경하면 원격 JVM 메트릭 수집을 시작합니다
# 기본값: false
remote.jmx.enabled=false

# 대상 JVM 서버의 호스트명 또는 IP
# 기본값: localhost
remote.jmx.host=localhost

# 대상 JVM의 JMX 포트 (-Dcom.sun.management.jmxremote.port 와 동일하게 설정)
# 기본값: 9999
remote.jmx.port=9999

# JMX 인증 사용자 / 비밀번호
# - 인증이 비활성화된 경우 빈값으로 두세요
# - 운영 환경에서는 인증을 활성화하고 별도 계정 사용을 권장합니다
# 기본값: (빈값)
remote.jmx.user=
remote.jmx.password=

# 원격 JVM 메트릭 수집 주기 (초)
# - 대시보드 갱신 주기와 맞춰 5초 이하 권장
# 기본값: 5
remote.jmx.poll.interval.sec=5

# 연결 끊김 시 재연결 시도 주기 (초)
# - 운영 환경에서는 15~30 사이 값 권장
# 기본값: 30
remote.jmx.reconnect.interval.sec=30


# ============================================================
#  [3] Agent HTTP 모니터링 (agent.*)
# ============================================================
#
#  JMX 없이 순수 HTTP 방식으로 대상 JVM의 스레드를 모니터링합니다.
#
#  ● 대상 JVM 정적 부착:
#    java -javaagent:java-monitor-1.5.0-agent.jar=port=7979 -jar myapp.jar
#
#  ● 동적 부착 (Attach API):
#    VirtualMachine vm = VirtualMachine.attach("PID");
#    vm.loadAgent("/path/to/java-monitor-1.5.0-agent.jar", "port=7979");
#    vm.detach();
#
#  ● Agent가 노출하는 주요 엔드포인트 (대상 JVM):
#    GET http://<agent.host>:<agent.port>/agent/threads
#    GET http://<agent.host>:<agent.port>/agent/jvm
#    GET http://<agent.host>:<agent.port>/agent/threaddump
#    GET http://<agent.host>:<agent.port>/agent/top10
#    GET http://<agent.host>:<agent.port>/agent/deadlocks
# ============================================================

# true 로 변경하면 Agent HTTP 수집을 시작합니다
# 기본값: false
agent.enabled=false

# ThreadMonitorAgent 가 실행 중인 대상 JVM의 호스트명 또는 IP
# 기본값: localhost
agent.host=localhost

# ThreadMonitorAgent HTTP 서버 포트 (-javaagent 인수의 port= 값과 동일하게 설정)
# 기본값: 7979
agent.port=7979

# Agent 에서 스레드 목록·JVM 메트릭을 수집하는 주기 (초)
# 기본값: 5
agent.poll.interval.sec=5


# ============================================================
#  [4] 경고 임계치 설정 (alert.*)
# ============================================================
#
#  임계치 초과 시 콘솔에 WARN 레벨 로그가 출력됩니다.
#  Slack·이메일 등 외부 알림은 로그 파일을
#  Fluentd / Filebeat 등 외부 도구로 수집하여 연동하세요.
# ============================================================

# Heap 사용률(%) 임계치 — 초과 시 WARN 출력
# 기본값: 85
alert.heap.percent=85

# 프로세스 CPU 사용률(%) 임계치 — 초과 시 WARN 출력
# 기본값: 80
alert.cpu.percent=80

# 트랜잭션 스팬 오류율(%) 임계치 (오류 스팬 / 전체 스팬 × 100)
# 기본값: 10
alert.error.rate.percent=10


# ============================================================
#  [환경별 설정 예시]
#  아래 주석을 참고해 환경에 맞게 값을 조정하세요.
# ============================================================

# ── 개발(dev) 환경 ───────────────────────────────────────────
# server.print.interval.sec=5      # 자주 출력해 빠르게 확인
# server.span.buffer.size=200
# alert.heap.percent=95            # 느슨하게
# alert.error.rate.percent=50

# ── 스테이징(staging) 환경 ──────────────────────────────────
# remote.jmx.enabled=true
# remote.jmx.host=staging-app-01
# remote.jmx.port=9999
# server.print.interval.sec=30

# ── 운영(prod) 환경 ─────────────────────────────────────────
# server.print.interval.sec=60     # 로그 최소화
# server.span.buffer.size=5000     # 더 많은 스팬 보관
# remote.jmx.enabled=true
# remote.jmx.host=prod-app-01
# remote.jmx.port=9999
# remote.jmx.user=monitoruser
# remote.jmx.password=<비밀번호>
# remote.jmx.reconnect.interval.sec=15
# alert.heap.percent=80            # 엄격하게
# alert.cpu.percent=70
# alert.error.rate.percent=5
